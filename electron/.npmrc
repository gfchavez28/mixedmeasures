# Block npm lifecycle scripts (preinstall/install/postinstall) on every install
# in this workspace — the same guard `frontend/.npmrc` has carried since the
# supply-chain audit (#562a).
#
# Why here, when the tree has zero install scripts today (verified: no
# `hasInstallScript` entry in package-lock.json, and electron@42's own
# package.json declares no `scripts` at all — its binary is fetched by
# electron-builder/@electron/get at BUILD time, not by a postinstall)?
#
# Precisely because it costs nothing today. The June-2026 phantom-gyp campaign
# (57 packages executing a malicious binding.gyp through node-gyp at install
# time) is the shape this defends against: the exposure arrives with a
# compromised *dev*-dependency bump, on a machine that holds `gh` tokens and
# signing config. A guard added the day you need it is a guard you didn't have.
# npm v12 makes script-blocking the default; this front-runs that.
#
# If a future dependency legitimately needs an install script, it will fail
# LOUDLY here rather than silently executing — which is the correct trade.
ignore-scripts=true
